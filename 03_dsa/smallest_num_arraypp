#include <iostream>
using namespace std;
int main(){
    int nums[] = {3,29,7,-23,-3};
    int size = sizeof(nums)/sizeof(nums[0]);
    int smallest = INT_MAX;
    for(int i=0;i<size;i++){
        if(nums[i]<smallest){
            smallest = nums[i];
        }
    }
    cout<<"The smallest number is : "<<smallest<<endl;
    return 0;
}